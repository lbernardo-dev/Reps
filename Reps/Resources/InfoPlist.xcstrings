            "value" : "StreakRep"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep"
          }
        }
      }
    },
    "CFBundleName" : {
      "comment" : "Bundle name",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep"
          }
        }
      }
    },
    "NSAppleMusicUsageDescription" : {
      "comment" : "Privacy - Media Library Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep needs access to your music library to play motivational playlists during your workouts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep necesita acceso a tu biblioteca de música para reproducir playlists motivacionales durante tus entrenamientos."
          }
        }
      }
    },
    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep needs camera access to take progress photos and attach them to your workouts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep necesita acceso a la cámara para tomar fotos de progreso y asociarlas a tus entrenamientos."
          }
        }
      }
    },
    "NSHealthShareUsageDescription" : {
      "comment" : "Privacy - Health Share Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep reads Apple Health data such as weight, height, steps, calories, hydration, exercise, heart rate, and workouts to show your progress and recovery."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep lee datos de Apple Health como peso, altura, pasos, calorías, hidratación, ejercicio, pulso y entrenos para mostrar tu progreso y recuperación."
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "comment" : "Privacy - Health Update Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep can save your body metrics, hydration, dietary energy, and workouts to Apple Health when you choose to sync them."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep puede guardar en Apple Health tus métricas corporales, hidratación, energía ingerida y entrenos cuando eliges sincronizarlos."
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep necesita tu ubicación para registrar tus rutas de carrera y cardio al aire libre incluso cuando la pantalla está bloqueada."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep needs your location to record outdoor running and cardio routes even when the screen is locked."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep needs your location to record outdoor running and cardio routes in real time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep necesita tu ubicación para registrar tus rutas de carrera y cardio al aire libre en tiempo real."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Privacy - Microphone Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep needs microphone access to record voice notes inside your workouts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep necesita acceso al micrófono para grabar notas de voz dentro de tus entrenamientos."
          }
        }
      }
    },
    "NSMotionUsageDescription" : {
      "comment" : "Privacy - Motion Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep uses motion sensors to detect walking or running and suggest resuming a paused route."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep usa los sensores de movimiento para detectar caminata o carrera y sugerir reanudar una ruta pausada."
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "comment" : "Privacy - Photo Library Additions Usage Description",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep necesita permiso para guardar imágenes de progreso cuando eliges exportarlas o compartirlas."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep needs permission to save progress images when you choose to export or share them."
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription" : {
      "comment" : "Privacy - Photo Library Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep needs access to your photos to select progress images and attach them to your profile or workouts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "StreakRep necesita acceso a tus fotos para seleccionar imágenes de progreso y asociarlas a tu perfil o entrenamientos."
          }
        }
      }
    }
  },
  "version" : "1.0"
}
