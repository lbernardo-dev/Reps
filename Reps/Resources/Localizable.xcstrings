          "stringUnit" : {
            "state" : "translated",
            "value" : "Buen margen para una sesión productiva."
          }
        }
      }
    },
    "battery_charged_suggestion" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can progress if technique holds and the target RPE fits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes progresar si la técnica se mantiene y el RPE objetivo encaja."
          }
        }
      }
    },
    "battery_charged_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Training battery charged"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Batería de entreno cargada"
          }
        }
      }
    },
    "battery_critical_advice" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Critical State. Training now increases injury risk. We strongly recommend postponing or switching to low-intensity mobility, and cutting loads by 40%."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zona Crítica. Entrenar aquí puede causar sobreentrenamiento. Recomendamos posponer o cambiar a una sesión de estiramiento y descargar peso un 40%."
          }
        }
      }
    },
    "battery_critical_message" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accumulated fatigue exceeds your recent recovery."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fatiga acumulada supera tu recuperación reciente."
          }
        }
      }
    },
    "battery_critical_suggestion" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Switch to rest, mobility or a deload. If you train, cut volume 40% and avoid RPE 9-10."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia a descanso, movilidad o descarga. Si entrenas, reduce volumen 40% y evita RPE 9-10."
          }
        }
      }
    },
    "battery_critical_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Training battery critical"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Batería de entreno crítica"
          }
        }
      }
    },
    "battery_level_explainer_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "How your battery level works"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cómo funciona tu nivel de batería"
          }
        }
      }
    },
    "battery_level_formula_explanation" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Level = 100 minus Fatigue load plus Recovery credit, clamped between 5 and 100. Fatigue load adds up decayed recent training, your plan's upcoming pressure and any wellness penalties. Recovery credit adds up rest days, sleep, HRV and how you say you feel."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nivel = 100 menos Carga de fatiga más Crédito de recuperación, limitado entre 5 y 100. La carga de fatiga suma el entrenamiento reciente (con decaimiento), la presión de tu plan activo y las alertas de bienestar. El crédito de recuperación suma días de descanso, sueño, VFC y cómo dices sentirte."
          }
        }
      }
    },
    "battery_low_advice" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Low State. You can train but reduce accessories. Keep RPE target around 6-7 and rest at least 3 minutes between primary heavy sets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zona Baja. Puedes entrenar, pero modera el esfuerzo. Mantén el RPE objetivo en 6-7 y descansa un mínimo de 3 minutos entre series."
          }
        }
      }
    },
    "battery_low_message" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can train, but the room to progress is limited."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes entrenar, pero el margen para progresar es limitado."
          }
        }
      }
    },
    "battery_low_suggestion" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keep RPE 6-7, rest 2-3 min between hard sets and trim accessories."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén RPE 6-7, descansa 2-3 min entre series duras y recorta accesorios."
          }
        }
      }
    },
    "battery_low_title" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Training battery low"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Batería de entreno baja"
          }
        }
      }
    },
