        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estado crítico. El entrenamiento ahora aumenta el riesgo de lesiones. Recomendamos encarecidamente posponer o cambiar a movilidad de baja intensidad y reducir las cargas en un 40%."
          }
        }
      }
