      }
    },
    "Te sugerimos rutinas con ejercicios de bajo impacto (peso corporal o máquinas de cardio en el gimnasio) para cuidar tus articulaciones mientras mejoras tu salud metabólica." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We suggest routines with low-impact exercises (body weight or cardio machines at the gym) to take care of your joints while improving your metabolic health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te sugerimos rutinas con ejercicios de bajo impacto (peso corporal o máquinas de cardio en el gimnasio) para cuidar tus articulaciones mientras mejoras tu salud metabólica."
          }
        }
      }
    },
