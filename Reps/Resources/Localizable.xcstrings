    "battery_prime_advice" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prime State. Cellular homeostasis is fully restored. You have the optimal window to push intense sets and seek progressive overload."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zona Excelente. La homeostasis celular está al máximo. Tienes margen óptimo para empujar series pesadas e intentar sobrecarga progresiva."
          }
        }
      }
    },
    "battery_stable_advice" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Steady State. Perfect for standard routine training. Execute according to plan and respect complete rest periods between compound movements."
          }
        },
        "es" : {
