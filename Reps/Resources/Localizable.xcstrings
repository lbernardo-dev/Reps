          "stringUnit" : {
            "state" : "translated",
            "value" : "\\(weeks) weeks left. Long duration: we suggest doing a block of 8 to 12 weeks and then a secondary maintenance/definition plan of \\(weeks - 8) weeks."
          }
        },
