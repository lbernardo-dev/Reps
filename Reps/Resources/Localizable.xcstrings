    "Te encuentras en un rango de peso saludable. Tu plan se centrará en la recomposición corporal, mejorando tu fuerza y definición muscular en casa o en el gimnasio.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are in a healthy weight range. Your plan will focus on body recomposition, improving your strength and muscle definition at home or in the gym."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te encuentras en un rango de peso saludable. Tu plan se centrará en la recomposición corporal, mejorando tu fuerza y definición muscular en casa o en el gimnasio."
          }
        }
      }
    },
    "Te recordaremos que la prueba termina en 2 días.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We will remind you that the test ends in 2 days."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te recordaremos que la prueba termina en 2 días."
          }
        }
      }
    },
    "Te sugerimos rutinas con ejercicios de bajo impacto (peso corporal o máquinas de cardio en el gimnasio) para cuidar tus articulaciones mientras mejoras tu salud metabólica.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We suggest routines with low-impact exercises (body weight or cardio machines at the gym) to take care of your joints while improving your metabolic health."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Te sugerimos rutinas con ejercicios de bajo impacto (peso corporal o máquinas de cardio en el gimnasio) para cuidar tus articulaciones mientras mejoras tu salud metabólica."
          }
        }
      }
    },
