<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Reps</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.romerosoft.repsfitness</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>reps</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>Reps necesita acceso a tu biblioteca de música para reproducir playlists motivacionales durante tus entrenamientos.</string>
	<key>NSCameraUsageDescription</key>
	<string>Reps necesita acceso a la cámara para tomar fotos de progreso y adjuntarlas a tus entrenamientos.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Reps lee datos de Apple Health como peso, altura, pasos, calorías, hidratación, ejercicio, pulso y entrenos para mostrar tu progreso y recuperación.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Reps puede guardar en Apple Health tus métricas corporales, hidratación, energía ingerida y entrenos cuando eliges sincronizarlos.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Reps necesita tu ubicación para registrar tus rutas de carrera y cardio al aire libre en tiempo real.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Reps necesita acceso a tus fotos cuando eliges importar imágenes de progreso desde la galería.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiresFullScreen</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
</dict>
</plist>
